# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clave de servicio (SECRETA — solo servidor, nunca usar el prefijo NEXT_PUBLIC_).
# La usa createAdminClient() en src/lib/supabase/server.ts (dashboard, /jornada,
# /admin/jornadas, /api/auth). Si falta en el hosting, la app falla justo después
# de iniciar sesión ("Algo salió mal"). Cópiala desde Supabase > Project Settings
# > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
